import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

df = pd.read_csv(r"C:Data Set For Task-2026\Data Set For Task\1) iris.csv")
#print(df.head())
#print(df.info())

specie_setosa = df[df['species'] == 'setosa'] # isolating by species [isb]
print(specie_setosa.mean(numeric_only=True))
print(specie_setosa.median(numeric_only=True))
print(specie_setosa.mode(numeric_only=True))
print(specie_setosa.std(numeric_only=True))

specie_versicolor = df[df['species'] == 'versicolor'] # isb
print(specie_versicolor.mean(numeric_only=True))
print(specie_versicolor.median(numeric_only=True))
print(specie_versicolor.mode(numeric_only=True))
print(specie_versicolor.std(numeric_only=True))

specie_virginica = df[df['species'] == 'virginica'] # isb
print(specie_virginica.mean(numeric_only=True))
print(specie_virginica.median(numeric_only=True))
print(specie_virginica.mode(numeric_only=True))
